+@router.post("/products/{product_id}/track-view")
+async def track_product_view(product_id: str):
+    """Track product view for analytics. Called on every product page load."""
+    dynamodb_client = boto3.client("dynamodb", region_name=settings.AWS_REGION)
+    dynamodb_client.update_item(
+        TableName=settings.ANALYTICS_TABLE,
+        Key={"pk": {"S": f"VIEWS#{product_id}"}, "sk": {"S": "COUNTER"}},
+        UpdateExpression="ADD view_count :inc",
+        ExpressionAttributeValues={":inc": {"N": "1"}},
+    )
+    return {"status": "ok"}
